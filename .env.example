# Copy to .env and edit. Settings are read with COPA_ prefix.
COPA_HUB_URL=http://localhost:3000
COPA_ROOM_CODE=ABC123
COPA_API_KEY=gambi
COPA_REQUEST_TIMEOUT=30
COPA_SKILLS_DIR=skills

# --- Tools (todas opcionais — desligadas quando vazias) ---
