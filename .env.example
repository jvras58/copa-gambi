COPA_REDDIT_CLIENT_ID=
COPA_REDDIT_CLIENT_SECRET=
COPA_REDDIT_USER_AGENT=copa-gambi/0.1 (sentiment)

# football-data.org (stats): https://www.football-data.org/client/register
COPA_FOOTBALL_DATA_TOKEN=
